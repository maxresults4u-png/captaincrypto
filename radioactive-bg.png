<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Captain Crypto Super Slots</title>

<style>

/* RESET */
body {
  margin: 0;
  font-family: Arial, sans-serif;
  color: #39FF14;
}

/* BACKGROUND CONTAINER */
.bg-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  overflow: hidden;
}

/* BACKGROUND IMAGE */
.bg-image {
  width: 100%;
  height: 100%;
  background: url('radioactive-bg.png') no-repeat center center;
  background-size: cover;
  animation: slowZoom 20s ease-in-out infinite alternate;
}

/* ZOOM ANIMATION */
@keyframes slowZoom {
  0% { transform: scale(1); }
  100% { transform: scale(1.1); }
}

/* RADIOACTIVE GLOW */
.radiation-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(57,255,20,0.2) 0%, transparent 70%);
  animation: pulseGlow 4s infinite;
}

/* GLOW PULSE */
@keyframes pulseGlow {
  0% { opacity: 0.2; }
  50% { opacity: 0.6; }
  100% { opacity: 0.2; }
}

/* NEON FLICKER */
.neon-flicker {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0,255,100,0.05);
  animation: flicker 3s infinite;
}

/* FLICKER ANIMATION */
@keyframes flicker {
  0%, 100% { opacity: 0.1; }
  50% { opacity: 0.3; }
  52% { opacity: 0.05; }
  55% { opacity: 0.25; }
}

/* MAIN CONTENT */
.main-content {
  position: relative;
  z-index: 1;
  text-align: center;
  padding-top: 100px;
}

/* TITLE */
h1 {
  font-size: 3rem;
  text-shadow: 0 0 20px #39FF14;
}

/* BUTTON */
button {
  padding: 15px 30px;
  font-size: 18px;
  background: #39FF14;
  border: none;
  cursor: pointer;
  box-shadow: 0 0 20px #39FF14;
  transition: 0.3s;
}

button:hover {
  transform: scale(1.1);
  box-shadow: 0 0 40px #39FF14;
}

</style>
</head>

<body>

<!-- BACKGROUND -->
<div class="bg-container">
  <div class="bg-image"></div>
  <div class="radiation-glow"></div>
  <div class="neon-flicker"></div>
</div>

<!-- YOUR CONTENT -->
<div class="main-content">
  <h1>☢️ Captain Crypto Super Slots</h1>
  <p>Enter the Vault. Spin the Future.</p>
  <button onclick="alert('Launching Soon 🚀')">Play Now</button>
</div>

</body>
</html>
